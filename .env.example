# SecureChat Environment Configuration
# Copy this to .env and fill in your values

# Database
MONGO_USER=admin
MONGO_PASSWORD=change_this_mongo_password

# Redis
REDIS_PASSWORD=change_this_redis_password

# JWT Secrets (generate with: openssl rand -hex 64)
JWT_SECRET=change_this_jwt_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production

# VAPID Keys for Web Push Notifications
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@yourdomain.com

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=SecureChat <noreply@yourdomain.com>

# Client URL (used for CORS and push notification links)
CLIENT_URL=http://localhost

# Ports
HTTP_PORT=80
HTTPS_PORT=443

# API URLs (for frontend build)
VITE_API_URL=/api
VITE_WS_URL=/ws

# Node environment
NODE_ENV=production
ADMIN_USERNAMES=yourusername
